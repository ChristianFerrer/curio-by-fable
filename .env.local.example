# ═══════════════════════════════════════════════════════════
# .env.local.example — Variables de entorno para Curio by Fable
# Copia este archivo como .env.local y rellena los valores
# NUNCA subas .env.local a git
# ═══════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────
# Obtén estos valores en: Supabase Dashboard > Settings > API

# URL del proyecto (también debe ir en public/config.js)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clave anónima pública (también en public/config.js — es segura con RLS)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave de servicio — SOLO para serverless, NUNCA en el cliente
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe ───────────────────────────────────────────────────
# Obtén estos valores en: Stripe Dashboard > Developers > API Keys
# Usa claves de TEST (sk_test_ / pk_test_) para desarrollo
# Usa claves de LIVE (sk_live_ / pk_live_) en producción

# Clave secreta — SOLO para serverless, NUNCA en el cliente
STRIPE_SECRET_KEY=sk_test_...

# Clave publicable — también debe ir en public/config.js
STRIPE_PUBLISHABLE_KEY=pk_test_...
